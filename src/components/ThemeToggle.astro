---
// 3-state theme toggle: Light / Dark / System
// Click cycles through. Default: System.
---

<button
  class="theme-toggle"
  id="theme-toggle"
  type="button"
  aria-label="Toggle theme"
  title="Toggle theme (Light / Dark / System)"
>
  <span class="theme-icon" data-icon="system" aria-hidden="true">
    <!-- Sun -->
    <svg class="icon-sun" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" style="display:none">
      <circle cx="12" cy="12" r="5"/>
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
    </svg>
    <!-- Moon -->
    <svg class="icon-moon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" style="display:none">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <!-- Monitor (system) -->
    <svg class="icon-monitor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
      <rect x="2" y="3" width="20" height="14" rx="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </svg>
  </span>
</button>

<script is:inline>
  (function() {
    const STORAGE_KEY = 'notes:theme';
    const THEMES = ['light', 'dark', 'system'];
    const html = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function getTheme() {
      try { return localStorage.getItem(STORAGE_KEY) || 'system'; }
      catch { return 'system'; }
    }

    function applyTheme(theme) {
      if (theme === 'light' || theme === 'dark') {
        html.setAttribute('data-theme', theme);
      } else {
        html.removeAttribute('data-theme');
      }
      updateIcon(theme);
    }

    function updateIcon(theme) {
      const sun = btn.querySelector('.icon-sun');
      const moon = btn.querySelector('.icon-moon');
      const mon = btn.querySelector('.icon-monitor');
      if (!sun || !moon || !mon) return;
      sun.style.display = 'none';
      moon.style.display = 'none';
      mon.style.display = 'none';
      if (theme === 'light') sun.style.display = 'block';
      else if (theme === 'dark') moon.style.display = 'block';
      else mon.style.display = 'block';
      btn.setAttribute('aria-label', `Theme: ${theme} (click to change)`);
    }

    function cycle() {
      const current = getTheme();
      const idx = THEMES.indexOf(current);
      const next = THEMES[(idx + 1) % THEMES.length];
      try { localStorage.setItem(STORAGE_KEY, next); } catch {}
      applyTheme(next);
    }

    // Apply current theme on load (in case BaseLayout didn't pre-set it)
    applyTheme(getTheme());

    btn.addEventListener('click', cycle);
  })();
</script>
