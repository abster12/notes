---
export interface Props {
  href: string;
  title: string;
  description?: string;
  category?: string;
  difficulty?: string;
  readTime?: number;
  listenTime?: number;
  tags?: string[];
}
const { href, title, description, category, difficulty, readTime, listenTime, tags } = Astro.props;
const excerpt = description ? description.slice(0, 140) + (description.length > 140 ? '…' : '') : '';
---

<a href={href} class="card">
  {category && <div class="card-category">{category}</div>}
  <h3 class="card-title">{title}</h3>
  {excerpt && <p class="card-excerpt">{excerpt}</p>}
  <div class="card-meta">
    {difficulty && (
      <span class:list={['badge', `badge-${difficulty.toLowerCase()}`]}>
        {difficulty}
      </span>
    )}
    {readTime && <span class="meta-item">📖 {readTime}m</span>}
    {listenTime && <span class="meta-item">🔊 {listenTime}m</span>}
  </div>
  {tags && tags.length > 0 && (
    <div class="card-tags">
      {tags.slice(0, 4).map((tag: string) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: all 200ms;
  }
  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    text-decoration: none;
  }
  .card-category {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .card-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0 0 0.75rem;
    flex: 1;
  }
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 0.6rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }
  .badge {
    display: inline-block;
    padding: 0.15em 0.5em;
    border-radius: 4px;
    font-size: 0.7em;
    font-weight: 600;
    text-transform: capitalize;
  }
  .meta-item {
    display: inline-flex;
    gap: 0.2rem;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .tag {
    display: inline-block;
    background: var(--color-bg-code);
    color: var(--color-text-secondary);
    padding: 0.1em 0.5em;
    border-radius: 3px;
    font-size: 0.7em;
    font-family: var(--font-code);
  }
</style>
