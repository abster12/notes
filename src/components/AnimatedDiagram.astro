---
// Animated SVG diagram for flagship articles
export interface Props {
  title: string;
  svgContent: string;
  caption?: string;
}

const { title, svgContent, caption } = Astro.props;
---

<div class="animated-diagram">
  <div class="diagram-header">
    <span>{title}</span>
  </div>
  <div class="animated-diagram-svg" set:html={svgContent}></div>
  {caption && <p class="animated-diagram-caption">{caption}</p>}
</div>

<style>
  .animated-diagram-caption {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0.75rem 0 0;
    text-align: center;
    font-style: italic;
  }
</style>
