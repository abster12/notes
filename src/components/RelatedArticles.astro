---
// Related articles — based on shared tags + same category
export interface RelatedArticle {
  id: string;
  title: string;
  readTime?: number;
  category: 'system-design' | 'coding-interview' | 'interview-prep' | 'glossary';
}

export interface Props {
  currentSlug: string;
  currentCategory: string;
  currentTags: string[];
  candidates: RelatedArticle[];
  limit?: number;
}

const { currentSlug, currentCategory, currentTags, candidates, limit = 3 } = Astro.props;
const base = import.meta.env.BASE_URL;

const currentTagSet = new Set(currentTags || []);

const scored = candidates
  .filter((a) => a.id !== currentSlug)
  .map((a) => {
    let cat: 'system-design' | 'coding-interview' | 'interview-prep' | 'glossary' = 'glossary';
    if (a.id.startsWith('system-design/')) cat = 'system-design';
    else if (a.id.startsWith('coding-interview/')) cat = 'coding-interview';
    else if (a.id.startsWith('interview-prep/')) cat = 'interview-prep';
    // We don't have tags for candidates here, so score primarily by category
    const sameCategory = cat === currentCategory ? 1 : 0;
    return { article: a, category: cat, score: sameCategory };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, limit);

function urlFor(id: string): string {
  return `${base}${id.replace(/\.md$/, '')}/`;
}

const categoryLabel: Record<string, string> = {
  'system-design': 'System Design',
  'coding-interview': 'Coding Interview',
  'interview-prep': 'Interview Prep',
  'glossary': 'Glossary',
};
---

{scored.length > 0 && (
  <section class="related-articles">
    <h3>Related</h3>
    <div class="related-grid">
      {scored.map(({ article, category }) => (
        <a href={urlFor(article.id)} class="related-card">
          <div class="related-card-title">{article.title}</div>
          <div class="related-card-meta">
            {categoryLabel[category] || category}
            {article.readTime && <> · {article.readTime} min</>}
          </div>
        </a>
      ))}
    </div>
  </section>
)}
