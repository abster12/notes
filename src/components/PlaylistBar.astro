---
// Slide-up playlist queue bar
---

<div class="playlist-bar" id="playlist-bar" data-open="false">
  <div class="playlist-header">
    <div class="playlist-title">
      <span>Queue</span>
      <span class="playlist-count" id="playlist-count">0</span>
    </div>
    <button class="playlist-toggle-btn" id="playlist-close" aria-label="Close playlist">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
  </div>
  <div class="playlist-items" id="playlist-items">
    <div class="playlist-empty">Your queue is empty. Click + on any article to add it.</div>
  </div>
  <div class="playlist-header" style="border-top: 1px solid var(--color-border); border-bottom: none;">
    <button class="action-btn" id="playlist-clear" style="width: 100%; justify-content: center;">
      Clear all
    </button>
  </div>
</div>

<button class="playlist-mini-btn" id="playlist-mini-btn" aria-label="Open playlist">
  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
    <path d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"/>
  </svg>
  <span id="playlist-mini-count">0</span>
</button>

<script is:inline>
  (function() {
    const bar = document.getElementById('playlist-bar');
    const itemsEl = document.getElementById('playlist-items');
    const countEl = document.getElementById('playlist-count');
    const miniBtn = document.getElementById('playlist-mini-btn');
    const miniCountEl = document.getElementById('playlist-mini-count');
    const closeBtn = document.getElementById('playlist-close');
    const clearBtn = document.getElementById('playlist-clear');
    if (!bar || !itemsEl) return;

    // Wait for state module to load
    function whenReady(cb) {
      if (window.NotesPlaylist) { cb(); return; }
      let attempts = 0;
      const t = setInterval(function() {
        if (window.NotesPlaylist) { clearInterval(t); cb(); }
        else if (++attempts > 50) { clearInterval(t); }
      }, 100);
    }

    whenReady(function() {
      const NP = window.NotesPlaylist;

    function render() {
      const state = NP.getPlaylist();
      countEl.textContent = state.items.length;
      if (miniCountEl) miniCountEl.textContent = state.items.length;

      if (state.items.length === 0) {
        miniBtn.classList.remove('is-visible');
        bar.classList.remove('is-open');
        bar.dataset.open = 'false';
        itemsEl.innerHTML = '<div class="playlist-empty">Your queue is empty. Click + on any article to add it.</div>';
        return;
      }

      miniBtn.classList.add('is-visible');

      const currentSlug = state.items[state.currentIndex]?.slug;

      itemsEl.innerHTML = state.items.map((item, i) => {
        const isCurrent = item.slug === currentSlug;
        return `
          <div class="playlist-item ${isCurrent ? 'is-current' : ''}" data-slug="${escapeHtml(item.slug)}" data-url="${escapeHtml(item.url)}">
            <span class="playlist-item-num">${isCurrent ? '▶' : (i + 1)}</span>
            <span class="playlist-item-title">${escapeHtml(item.title)}</span>
            <button class="playlist-item-remove" data-remove="${escapeHtml(item.slug)}" aria-label="Remove">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
              </svg>
            </button>
          </div>
        `;
      }).join('');
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function open() {
      bar.classList.add('is-open');
      bar.dataset.open = 'true';
    }
    function close() {
      bar.classList.remove('is-open');
      bar.dataset.open = 'false';
    }
    function toggle() {
      if (bar.dataset.open === 'true') close();
      else open();
    }

    miniBtn?.addEventListener('click', toggle);
    closeBtn?.addEventListener('click', close);
    clearBtn?.addEventListener('click', () => {
      if (confirm('Clear the entire queue?')) NP.clearPlaylist();
    });

    itemsEl.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;

      const removeBtn = target.closest('[data-remove]');
      if (removeBtn) {
        e.stopPropagation();
        const slug = removeBtn.getAttribute('data-remove');
        if (slug) NP.removeFromPlaylist(slug);
        return;
      }

      const item = target.closest('.playlist-item');
      if (item) {
        const url = item.getAttribute('data-url');
        const slug = item.getAttribute('data-slug');
        if (slug) NP.setCurrent(slug);
        if (url) location.href = url;
      }
    });

    document.addEventListener('notes:playlist:changed', render);
    render();

    // Expose for other components (e.g., MobileTabBar)
    window.NotesPlaylistUI = { open, close, toggle };
    }); // end whenReady
  })();
</script>
