---
export interface Props {
  title: string;
  articleSelector: string;
}

const { title, articleSelector } = Astro.props;
---

<div class="audio-player" id="audio-player" data-title={title} data-selector={articleSelector}>
  <div class="player-collapsed">
    <button class="player-btn play-btn" id="player-toggle" aria-label="Play/Pause">
      <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M8 5v14l11-7z"/>
      </svg>
      <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" style="display:none">
        <path d="M6 4h4v16H6zm8 0h4v16h-4z"/>
      </svg>
    </button>
    <div class="player-info">
      <span class="player-label">Read Aloud</span>
      <span class="player-progress" id="player-progress">0%</span>
    </div>
    <button class="player-btn expand-btn" id="player-expand" aria-label="Show controls">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M7 10l5 5 5-5z"/>
      </svg>
    </button>
  </div>

  <div class="player-expanded" id="player-expanded" style="display:none">
    <div class="player-progress-bar">
      <div class="player-progress-fill" id="player-progress-fill"></div>
    </div>
    <div class="player-controls">
      <div class="control-group">
        <button class="control-btn" id="player-skip-back" aria-label="Skip back 30s">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M11 18V6l-8.5 6 8.5 6zm.5-6l8.5 6V6l-8.5 6z"/>
          </svg>
        </button>
        <button class="control-btn primary" id="player-toggle-2" aria-label="Play/Pause">
          <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="display:none">
            <path d="M6 4h4v16H6zm8 0h4v16h-4z"/>
          </svg>
        </button>
        <button class="control-btn" id="player-skip-forward" aria-label="Skip forward 30s">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M13 6v12l8.5-6L13 6zM4 18l8.5-6L4 6v12z"/>
          </svg>
        </button>
        <button class="control-btn" id="player-stop" aria-label="Stop">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <rect x="6" y="6" width="12" height="12"/>
          </svg>
        </button>
      </div>
      <div class="control-group">
        <label class="control-label">Speed</label>
        <select class="control-select" id="player-speed">
          <option value="0.75">0.75×</option>
          <option value="1" selected>1×</option>
          <option value="1.25">1.25×</option>
          <option value="1.5">1.5×</option>
          <option value="2">2×</option>
        </select>
      </div>
      <div class="control-group">
        <label class="control-label">Voice</label>
        <select class="control-select" id="player-voice">
          <option value="default">System default</option>
        </select>
      </div>
      <button class="control-btn collapse-btn" id="player-collapse" aria-label="Hide controls">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M7 14l5-5 5 5z"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .audio-player {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 100;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    font-family: var(--font-body);
    overflow: hidden;
    transition: all 200ms;
  }
  .player-collapsed {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    min-width: 200px;
  }
  .player-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .player-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .player-progress {
    font-size: 0.75rem;
    color: var(--color-text);
    font-family: var(--font-code);
  }
  .player-btn {
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.3rem;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms;
  }
  .player-btn:hover {
    background: var(--color-bg-code);
  }
  .play-btn {
    background: var(--color-accent);
    color: white;
  }
  .play-btn:hover {
    background: var(--color-accent-hover);
  }
  .player-expanded {
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-border);
  }
  .player-progress-bar {
    height: 4px;
    background: var(--color-bg-code);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .player-progress-fill {
    height: 100%;
    background: var(--color-accent);
    width: 0%;
    transition: width 200ms;
  }
  .player-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .control-group {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .control-btn {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 150ms;
  }
  .control-btn:hover {
    background: var(--color-bg-code);
    border-color: var(--color-accent);
  }
  .control-btn.primary {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
  .control-btn.primary:hover {
    background: var(--color-accent-hover);
  }
  .control-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .control-select {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.3rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-family: var(--font-body);
    cursor: pointer;
  }
  .control-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .audio-player.is-playing {
    border-color: var(--color-accent);
  }
  @media (max-width: 768px) {
    .audio-player {
      bottom: 0.5rem;
      right: 0.5rem;
      left: 0.5rem;
    }
    .player-collapsed {
      min-width: 0;
    }
  }
</style>

<script>
  // AudioPlayer — Web Speech API narration
  // Runs in the browser. No backend. No API cost.

  class AudioPlayer {
    private root: HTMLElement;
    private title: string;
    private selector: string;
    private chunks: string[] = [];
    private currentChunk: number = 0;
    private isPlaying: boolean = false;
    private isPaused: boolean = false;
    private rate: number = 1.0;
    private voice: SpeechSynthesisVoice | null = null;
    private sessionKey: string;

    constructor(root: HTMLElement) {
      this.root = root;
      this.title = root.dataset.title || 'Article';
      this.selector = root.dataset.selector || '.article-prose';
      this.sessionKey = `notes:audio:${location.pathname}`;
      this.init();
    }

    private init() {
      this.loadVoices();
      speechSynthesis.addEventListener('voiceschanged', () => this.loadVoices());
      this.prepareChunks();
      this.attachEvents();
      this.restoreSession();
    }

    private loadVoices() {
      const voices = speechSynthesis.getVoices();
      const voiceSelect = document.getElementById('player-voice') as HTMLSelectElement;
      if (!voiceSelect) return;
      const previous = voiceSelect.value;
      voiceSelect.innerHTML = '<option value="default">System default</option>' +
        voices
          .filter(v => v.lang.startsWith('en'))
          .map(v => `<option value="${v.name}">${v.name} (${v.lang})</option>`)
          .join('');
      if (previous) voiceSelect.value = previous;
      // Pick a high-quality default voice if available
      const preferred = voices.find(v =>
        v.name.includes('Samantha') || v.name.includes('Karen') ||
        v.name.includes('Daniel') || v.name.includes('Google') ||
        v.name.includes('Microsoft') || v.name.includes('Aria') ||
        v.name.includes('Jenny') || v.name.includes('Guy')
      );
      if (preferred) this.voice = preferred;
    }

    private prepareChunks() {
      const el = document.querySelector(this.selector);
      if (!el) {
        this.chunks = [`${this.title}. Content not available.`];
        return;
      }
      // Walk through text, split by headings into sections, then by paragraphs
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
      const sections: { heading: string; text: string }[] = [];
      let currentSection: { heading: string; text: string } = { heading: this.title, text: '' };
      let lastBlock: HTMLElement | null = null;

      const blocks = el.querySelectorAll('h1, h2, h3, p, li, blockquote, td, th, dt, dd');
      blocks.forEach((block) => {
        const text = (block.textContent || '').replace(/\s+/g, ' ').trim();
        if (!text) return;
        if (block.tagName.match(/^H[123]$/)) {
          if (currentSection.text) sections.push(currentSection);
          currentSection = { heading: text, text: '' };
        } else {
          // Skip code blocks (they read poorly with TTS)
          if (block.closest('pre')) return;
          currentSection.text += (currentSection.text ? ' ' : '') + text;
        }
      });
      if (currentSection.text) sections.push(currentSection);

      // Flatten to chunks. Web Speech API has a ~15s utterance limit in Chrome.
      // Split long sections by sentences.
      const maxChunkLen = 1500;
      for (const section of sections) {
        const text = section.heading + '. ' + section.text;
        if (text.length <= maxChunkLen) {
          this.chunks.push(text);
        } else {
          // Split by sentence
          const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
          let buffer = '';
          for (const sentence of sentences) {
            if ((buffer + sentence).length > maxChunkLen && buffer) {
              this.chunks.push(buffer.trim());
              buffer = sentence;
            } else {
              buffer += sentence;
            }
          }
          if (buffer) this.chunks.push(buffer.trim());
        }
      }

      if (this.chunks.length === 0) {
        this.chunks = [`${this.title}. No readable content found.`];
      }
    }

    private attachEvents() {
      const toggle = (e: Event) => {
        e.preventDefault();
        if (this.isPlaying && !this.isPaused) {
          this.pause();
        } else if (this.isPaused) {
          this.resume();
        } else {
          this.play();
        }
      };
      document.getElementById('player-toggle')?.addEventListener('click', toggle);
      document.getElementById('player-toggle-2')?.addEventListener('click', toggle);
      document.getElementById('player-stop')?.addEventListener('click', () => this.stop());
      document.getElementById('player-skip-forward')?.addEventListener('click', () => this.skip(1));
      document.getElementById('player-skip-back')?.addEventListener('click', () => this.skip(-1));
      document.getElementById('player-expand')?.addEventListener('click', () => this.expand(true));
      document.getElementById('player-collapse')?.addEventListener('click', () => this.expand(false));

      const speedSelect = document.getElementById('player-speed') as HTMLSelectElement;
      speedSelect?.addEventListener('change', () => {
        this.rate = parseFloat(speedSelect.value);
        if (this.isPlaying && !this.isPaused) {
          // restart current chunk with new rate
          const idx = this.currentChunk;
          speechSynthesis.cancel();
          this.currentChunk = idx;
          this.isPlaying = false;
          this.speakChunk(idx);
        }
      });

      const voiceSelect = document.getElementById('player-voice') as HTMLSelectElement;
      voiceSelect?.addEventListener('change', () => {
        const name = voiceSelect.value;
        if (name === 'default') {
          this.voice = null;
        } else {
          this.voice = speechSynthesis.getVoices().find(v => v.name === name) || null;
        }
        if (this.isPlaying && !this.isPaused) {
          const idx = this.currentChunk;
          speechSynthesis.cancel();
          this.currentChunk = idx;
          this.isPlaying = false;
          this.speakChunk(idx);
        }
      });
    }

    private play() {
      this.isPlaying = true;
      this.isPaused = false;
      this.root.classList.add('is-playing');
      this.swapIcon(true);
      this.speakChunk(this.currentChunk);
    }

    private pause() {
      this.isPaused = true;
      this.isPlaying = true;
      speechSynthesis.pause();
      this.swapIcon(false);
    }

    private resume() {
      this.isPaused = false;
      speechSynthesis.resume();
      this.swapIcon(true);
    }

    private stop() {
      this.isPlaying = false;
      this.isPaused = false;
      this.currentChunk = 0;
      speechSynthesis.cancel();
      this.root.classList.remove('is-playing');
      this.swapIcon(false);
      this.updateProgress();
    }

    private skip(direction: number) {
      // Skip by ~30s, estimated as 1-2 chunks
      const steps = direction > 0 ? 2 : -2;
      this.currentChunk = Math.max(0, Math.min(this.chunks.length - 1, this.currentChunk + steps));
      speechSynthesis.cancel();
      this.isPlaying = false;
      this.speakChunk(this.currentChunk);
    }

    private speakChunk(index: number) {
      if (index >= this.chunks.length) {
        this.stop();
        return;
      }
      this.currentChunk = index;
      const utterance = new SpeechSynthesisUtterance(this.chunks[index]);
      utterance.rate = this.rate;
      if (this.voice) utterance.voice = this.voice;
      utterance.onend = () => {
        if (this.isPlaying && !this.isPaused) {
          this.currentChunk++;
          this.saveSession();
          this.speakChunk(this.currentChunk);
        }
      };
      this.isPlaying = true;
      this.root.classList.add('is-playing');
      this.swapIcon(true);
      speechSynthesis.speak(utterance);
      this.saveSession();
    }

    private swapIcon(playing: boolean) {
      document.querySelectorAll('.icon-play').forEach(el => (el as HTMLElement).style.display = playing ? 'none' : 'block');
      document.querySelectorAll('.icon-pause').forEach(el => (el as HTMLElement).style.display = playing ? 'block' : 'none');
    }

    private updateProgress() {
      const pct = this.chunks.length > 0 ? Math.round((this.currentChunk / this.chunks.length) * 100) : 0;
      const progressText = document.getElementById('player-progress');
      const progressFill = document.getElementById('player-progress-fill');
      if (progressText) progressText.textContent = `${pct}%`;
      if (progressFill) progressFill.style.width = `${pct}%`;
    }

    private expand(expand: boolean) {
      const expanded = document.getElementById('player-expanded');
      if (expanded) expanded.style.display = expand ? 'block' : 'none';
    }

    private saveSession() {
      try {
        sessionStorage.setItem(this.sessionKey, JSON.stringify({
          chunk: this.currentChunk,
          total: this.chunks.length,
          timestamp: Date.now(),
        }));
      } catch {}
      this.updateProgress();
    }

    private restoreSession() {
      try {
        const data = sessionStorage.getItem(this.sessionKey);
        if (data) {
          const { chunk, total } = JSON.parse(data);
          this.currentChunk = Math.min(chunk, total - 1);
          this.updateProgress();
        }
      } catch {}
    }
  }

  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    const player = document.getElementById('audio-player');
    if (player) new AudioPlayer(player);
  });
</script>
