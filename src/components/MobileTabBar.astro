---
// Mobile bottom tab bar (visible < 768px)
const base = import.meta.env.BASE_URL;
---

<nav class="mobile-tab-bar" aria-label="Mobile navigation">
  <a href={base} class="mobile-tab" data-match="/">
    <span class="mobile-tab-icon">⌂</span>
    <span>Home</span>
  </a>
  <a href={`${base}system-design/`} class="mobile-tab" data-match="/system-design/">
    <span class="mobile-tab-icon">⚙</span>
    <span>SD</span>
  </a>
  <a href={`${base}coding-interview/`} class="mobile-tab" data-match="/coding-interview/">
    <span class="mobile-tab-icon">⌨</span>
    <span>CIP</span>
  </a>
  <a href={`${base}interview-prep/`} class="mobile-tab" data-match="/interview-prep/">
    <span class="mobile-tab-icon">★</span>
    <span>Prep</span>
  </a>
  <button class="mobile-tab" id="mobile-search-btn" type="button">
    <span class="mobile-tab-icon">🔍</span>
    <span>Search</span>
  </button>
  <button class="mobile-tab" id="mobile-playlist-btn" type="button">
    <span class="mobile-tab-icon">≡</span>
    <span>Queue</span>
  </button>
</nav>

<script is:inline>
  (function() {
    const path = location.pathname;

    // Highlight current section
    document.querySelectorAll('.mobile-tab[data-match]').forEach(el => {
      const match = el.getAttribute('data-match');
      if (match === '/' && (path === '/' || path.endsWith('/notes/') || path.endsWith('/notes'))) {
        el.classList.add('active');
      } else if (match && match !== '/' && path.includes(match)) {
        el.classList.add('active');
      }
    });

    // Search button → focus pagefind input
    document.getElementById('mobile-search-btn')?.addEventListener('click', () => {
      // Try pagefind first
      const pagefind = document.querySelector('.pagefind-ui__search-input') || document.querySelector('input[type="search"]');
      if (pagefind) {
        pagefind.focus();
        pagefind.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      // Fallback to nav search
      const navSearch = document.querySelector('.nav-search input');
      if (navSearch) {
        navSearch.focus();
        navSearch.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });

    // Playlist button → toggle playlist bar (with retry if UI not ready)
    const playlistBtn = document.getElementById('mobile-playlist-btn');
    if (playlistBtn) {
      playlistBtn.addEventListener('click', () => {
        if (window.NotesPlaylistUI) {
          window.NotesPlaylistUI.toggle();
        } else {
          // Retry: UI module may still be loading
          let attempts = 0;
          const retry = setInterval(() => {
            if (window.NotesPlaylistUI) {
              clearInterval(retry);
              window.NotesPlaylistUI.toggle();
            } else if (++attempts > 30) {
              clearInterval(retry);
            }
          }, 100);
        }
      });
    }
  })();
</script>
