---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import PlaylistBar from '../components/PlaylistBar.astro';
import MobileTabBar from '../components/MobileTabBar.astro';
import KeyboardShortcuts from '../components/KeyboardShortcuts.astro';

export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const { title, description = 'Knowledge site for System Design and Coding Interview Prep — 78 in-depth articles plus interview prep, narrated via browser TTS.', activeNav = '' } = Astro.props;
const fullTitle = title === 'Notes' ? title : `${title} · Notes`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Pre-paint theme script — prevents flash of incorrect theme (Phase 2.2) -->
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('notes:theme') || 'system';
          if (t === 'light' || t === 'dark') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href={import.meta.env.BASE_URL} class="nav-logo">
          <span class="logo-mark">τ</span>
          <span class="logo-text">Notes</span>
        </a>
        <div class="nav-links" id="nav-links">
          <a href={`${import.meta.env.BASE_URL}system-design/`} class:list={['nav-link', activeNav === 'system-design' && 'active']}>
            System Design
          </a>
          <a href={`${import.meta.env.BASE_URL}coding-interview/`} class:list={['nav-link', activeNav === 'coding-interview' && 'active']}>
            Coding Interview
          </a>
          <a href={`${import.meta.env.BASE_URL}interview-prep/`} class:list={['nav-link', activeNav === 'interview-prep' && 'active']}>
            Interview Prep
          </a>
          <a href={`${import.meta.env.BASE_URL}glossary/`} class:list={['nav-link', activeNav === 'glossary' && 'active']}>
            Glossary
          </a>
        </div>
        <div class="nav-search" data-pagefind-search></div>
        <ThemeToggle />
        <button class="nav-drawer-toggle" id="nav-drawer-toggle" aria-label="Toggle menu">
          <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
            <path d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"/>
          </svg>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>
          Built by <a href="https://github.com/abster12">abster12</a> · Hosted on GitHub Pages ·
          <a href="https://github.com/abster12/notes">Source</a>
        </p>
      </div>
    </footer>

    <MobileTabBar />
    <PlaylistBar />
    <KeyboardShortcuts />

    <!-- Client-side state modules (progress, playlist) — loaded on every page -->
    <script>
      import '/src/scripts/progress.ts';
      import '/src/scripts/playlist.ts';
    </script>

    <!-- Pagefind UI init -->
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.PagefindUI) {
          new window.PagefindUI({
            element: '[data-pagefind-search]',
            showImages: false,
            showSubResults: true,
            resetStyles: false,
          });
        }
      });
    </script>
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}pagefind/pagefind-ui.css`} />
    <script src={`${import.meta.env.BASE_URL}pagefind/pagefind-ui.js`} is:inline></script>

    <script is:inline>
      // Mobile nav drawer
      (function() {
        const toggle = document.getElementById('nav-drawer-toggle');
        const links = document.getElementById('nav-links');
        if (toggle && links) {
          toggle.addEventListener('click', () => links.classList.toggle('is-open'));
        }
      })();
    </script>

    <script is:inline>
      // Collapsible category toggle — single event listener via delegation
      document.addEventListener('click', function(e) {
        const btn = e.target.closest('[data-collapse-toggle]');
        if (!btn) return;
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const contentId = btn.getAttribute('aria-controls');
        const content = document.getElementById(contentId);
        if (!content) return;

        if (expanded) {
          btn.setAttribute('aria-expanded', 'false');
          content.style.display = 'none';
        } else {
          btn.setAttribute('aria-expanded', 'true');
          content.style.display = 'block';
        }
      });
    </script>

    <style>
      .site-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--color-bg) 95%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
      }
      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text);
        text-decoration: none;
        font-weight: 700;
      }
      .nav-logo:hover { text-decoration: none; }
      .logo-mark {
        font-size: 1.5rem;
        color: var(--color-accent);
        font-family: var(--font-code);
      }
      .logo-text { font-size: 1.1rem; }
      .nav-links {
        display: flex;
        gap: 1.5rem;
        flex: 1;
      }
      .nav-link {
        color: var(--color-text-secondary);
        font-weight: 500;
        font-size: 0.95rem;
        transition: color 200ms;
      }
      .nav-link:hover, .nav-link.active {
        color: var(--color-accent);
        text-decoration: none;
      }
      .nav-search {
        position: relative;
        flex: 0 1 240px;
        min-width: 0;
      }
      .nav-search .pagefind-ui__form,
      .nav-search form {
        position: relative;
      }
      .nav-search .pagefind-ui__search-input,
      .nav-search input[type="text"],
      .search-input {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        font-size: 0.9rem;
        width: 100%;
        max-width: 240px;
        font-family: var(--font-body);
      }
      .nav-search .pagefind-ui__search-input:focus,
      .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
      }
      .nav-search .pagefind-ui__clear-near {
        right: 0.4rem;
      }
      .site-footer {
        margin-top: 6rem;
        padding: 2rem 0;
        border-top: 1px solid var(--color-border);
        text-align: center;
        color: var(--color-text-secondary);
        font-size: 0.9rem;
      }
      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .site-footer a { color: var(--color-text); }

      @media (max-width: 768px) {
        .nav-inner {
          flex-wrap: wrap;
          gap: 0.75rem;
        }
        .nav-search {
          order: 5;
          flex-basis: 100%;
        }
        .search-input {
          width: 100%;
        }
        .nav-drawer-toggle {
          display: inline-flex !important;
        }
        .nav-links {
          display: none;
        }
        .nav-links.is-open {
          display: flex;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: var(--color-bg-card);
          border-bottom: 1px solid var(--color-border);
          flex-direction: column;
          padding: 1rem 1.5rem;
          gap: 0.75rem;
          z-index: 70;
        }
      }
    </style>
  </body>
</html>
