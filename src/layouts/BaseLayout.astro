---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const { title, description = 'Premium knowledge site for System Design and Coding Interview Prep — 74 in-depth articles, narrated via browser TTS.', activeNav = '' } = Astro.props;
const fullTitle = title === 'Notes' ? title : `${title} · Notes`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="logo-mark">τ</span>
          <span class="logo-text">Notes</span>
        </a>
        <div class="nav-links">
          <a href="/system-design/" class:list={['nav-link', activeNav === 'system-design' && 'active']}>
            System Design
          </a>
          <a href="/coding-interview/" class:list={['nav-link', activeNav === 'coding-interview' && 'active']}>
            Coding Interview
          </a>
          <a href="/glossary/" class:list={['nav-link', activeNav === 'glossary' && 'active']}>
            Glossary
          </a>
        </div>
        <div class="nav-search" data-pagefind-search>
          <input type="text" placeholder="Search…" class="search-input" />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>
          Built by <a href="https://github.com/abster12">abster12</a> · Hosted on GitHub Pages ·
          <a href="https://github.com/abster12/notes">Source</a>
        </p>
      </div>
    </footer>

    <script is:inline>
      // Pagefind UI init (after page load)
      window.addEventListener('DOMContentLoaded', () => {
        // @ts-ignore
        if (window.PagefindUI) {
          // @ts-ignore
          new window.PagefindUI({
            element: '[data-pagefind-search]',
            showImages: false,
            showSubResults: true,
            resetStyles: false,
          });
        }
      });
    </script>
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>

    <style>
      .site-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--color-bg) 95%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
      }
      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
      }
      .nav-logo {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        color: var(--color-text);
        text-decoration: none;
        font-weight: 700;
      }
      .nav-logo:hover {
        text-decoration: none;
      }
      .logo-mark {
        font-size: 1.5rem;
        color: var(--color-accent);
        font-family: var(--font-code);
      }
      .logo-text {
        font-size: 1.1rem;
      }
      .nav-links {
        display: flex;
        gap: 1.5rem;
        flex: 1;
      }
      .nav-link {
        color: var(--color-text-secondary);
        font-weight: 500;
        font-size: 0.95rem;
        transition: color 200ms;
      }
      .nav-link:hover, .nav-link.active {
        color: var(--color-accent);
        text-decoration: none;
      }
      .nav-search {
        position: relative;
      }
      .search-input {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        font-size: 0.9rem;
        width: 220px;
        font-family: var(--font-body);
      }
      .search-input:focus {
        outline: none;
        border-color: var(--color-accent);
      }
      .site-footer {
        margin-top: 6rem;
        padding: 2rem 0;
        border-top: 1px solid var(--color-border);
        text-align: center;
        color: var(--color-text-secondary);
        font-size: 0.9rem;
      }
      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .site-footer a {
        color: var(--color-text);
      }
      @media (max-width: 768px) {
        .nav-inner {
          flex-wrap: wrap;
          gap: 0.75rem;
        }
        .nav-search {
          order: 3;
          flex-basis: 100%;
        }
        .search-input {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
