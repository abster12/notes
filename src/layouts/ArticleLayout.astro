---
import BaseLayout from './BaseLayout.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import LearningPathNav from '../components/LearningPathNav.astro';

export interface Props {
  title: string;
  description?: string;
  difficulty?: string;
  readTime?: number;
  listenTime?: number;
  tags?: string[];
  category?: string;
  categorySlug?: string;
  activeNav?: string;
  slug: string;
  headings: { depth: number; slug: string; text: string }[];
}

const {
  title, description, difficulty, readTime, listenTime,
  tags, category, categorySlug, activeNav, slug, headings,
} = Astro.props;
---

<BaseLayout title={title} description={description} activeNav={activeNav}>
  <div class="article-layout">
    <aside class="toc-sidebar">
      <TableOfContents headings={headings.filter(h => h.depth === 2 || h.depth === 3)} />
    </aside>

    <article class="article-main">
      <header class="article-header">
        {category && categorySlug && (
          <a href={`/${categorySlug}/`} class="article-category">{category}</a>
        )}
        <h1 class="article-title">{title}</h1>
        <div class="article-meta">
          {difficulty && (
            <span class:list={['badge', `badge-${difficulty.toLowerCase()}`]}>
              {difficulty}
            </span>
          )}
          {readTime && (
            <span class="meta-item">
              <span class="meta-icon">📖</span> {readTime} min read
            </span>
          )}
          {listenTime && (
            <span class="meta-item">
              <span class="meta-icon">🔊</span> {listenTime} min listen
            </span>
          )}
        </div>
        {tags && tags.length > 0 && (
          <div class="article-tags">
            {tags.slice(0, 8).map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="article-prose">
        <slot />
      </div>

      <LearningPathNav slug={slug} category={category} />
    </article>
  </div>

  <AudioPlayer title={title} articleSelector=".article-prose" />

  <style>
    .article-layout {
      max-width: 1200px;
      margin: 2rem auto 4rem;
      padding: 0 1.5rem;
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 3rem;
      align-items: start;
    }
    .toc-sidebar {
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      padding-right: 1rem;
    }
    .article-main {
      min-width: 0;
      max-width: 820px;
    }
    .article-header {
      margin-bottom: 2rem;
    }
    .article-category {
      display: inline-block;
      color: var(--color-accent);
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .article-title {
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1.2;
      margin: 0 0 1rem;
    }
    .article-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      color: var(--color-text-secondary);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    .badge {
      display: inline-block;
      padding: 0.2em 0.6em;
      border-radius: 4px;
      font-size: 0.8em;
      font-weight: 600;
      text-transform: capitalize;
    }
    .meta-item {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    .meta-icon {
      opacity: 0.7;
    }
    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .tag {
      display: inline-block;
      background: var(--color-bg-code);
      color: var(--color-text-secondary);
      padding: 0.2em 0.6em;
      border-radius: 4px;
      font-size: 0.8em;
      font-family: var(--font-code);
    }
    @media (max-width: 1024px) {
      .article-layout {
        grid-template-columns: 1fr;
      }
      .toc-sidebar {
        display: none;
      }
    }
    @media (max-width: 768px) {
      .article-title {
        font-size: 1.8rem;
      }
    }
  </style>
</BaseLayout>
