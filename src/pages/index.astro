---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');

const sdCount = articles.filter((a: any) => a.id.startsWith('system-design/')).length;
const cipCount = articles.filter((a: any) => a.id.startsWith('coding-interview/')).length;
const glossaryCount = articles.filter((a: any) => a.id.startsWith('glossary/')).length;

// Total word count for "35 hours of audio" stat
const totalWords = articles.reduce((sum: number, a: any) => {
  const text = a.body || '';
  return sum + text.split(/\s+/).filter(Boolean).length;
}, 0);
const hoursOfReading = Math.round(totalWords / 250 / 60);
const hoursOfAudio = Math.round(hoursOfReading * 1.4);
---

<BaseLayout title="Notes" description="Premium knowledge site for System Design and Coding Interview Prep — 74 in-depth articles, narrated via browser TTS.">
  <div class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">A LEARNING KNOWLEDGE SITE</p>
      <h1 class="hero-title">Master System Design<br />& Coding Interviews</h1>
      <p class="hero-subtitle">
        74 in-depth articles covering foundational concepts to staff-engineer depth.
        Read them in your browser, or have them narrated to you on your commute.
      </p>
      <div class="hero-cta">
        <a href="/system-design/" class="btn btn-primary">System Design →</a>
        <a href="/coding-interview/" class="btn btn-secondary">Coding Interview Prep →</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">{sdCount}</div>
          <div class="stat-label">System Design articles</div>
        </div>
        <div class="stat">
          <div class="stat-num">{cipCount}</div>
          <div class="stat-label">Coding Interview patterns</div>
        </div>
        <div class="stat">
          <div class="stat-num">{hoursOfReading}h</div>
          <div class="stat-label">of reading</div>
        </div>
        <div class="stat">
          <div class="stat-num">{hoursOfAudio}h</div>
          <div class="stat-label">of audio (browser TTS)</div>
        </div>
      </div>
    </div>
  </div>

  <section class="features">
    <div class="features-inner">
      <div class="feature">
        <div class="feature-icon">📖</div>
        <h3 class="feature-title">Read</h3>
        <p class="feature-text">
          Clean typography, syntax-highlighted code, searchable glossary. Built for long-form learning without eye strain.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon">🔊</div>
        <h3 class="feature-title">Listen</h3>
        <p class="feature-text">
          Every article has a "Read Aloud" button. Browser TTS narrates the content — free, offline-capable, no API key needed.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon">🔍</div>
        <h3 class="feature-title">Search</h3>
        <p class="feature-text">
          Full-text search across all articles. Jump to a topic mid-sentence. Find the answer, don't lose your place.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 1.5rem 4rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-card) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-eyebrow {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: var(--color-text);
  }
  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 0 2.5rem;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 200ms;
  }
  .btn-primary {
    background: var(--color-accent);
    color: white;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    text-decoration: none;
    transform: translateY(-1px);
  }
  .btn-secondary {
    background: var(--color-bg-card);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }
  .stat {
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    font-family: var(--font-code);
  }
  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }
  .features {
    padding: 4rem 1.5rem;
  }
  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .feature {
    text-align: center;
    padding: 1.5rem;
  }
  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .feature-title {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .feature-text {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.2rem;
    }
    .hero-subtitle {
      font-size: 1.05rem;
    }
    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .features-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
