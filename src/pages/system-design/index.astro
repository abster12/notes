---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySection from '../../components/CategorySection.astro';
import { getCollection } from 'astro:content';
import { systemDesignCategories } from '../../data/articleCategories';

const allArticles = await getCollection('articles', (entry: any) => entry.id.startsWith('system-design/'));

// Extract Summary & Interview Framing as the description
function extractDescription(body: string): string {
  if (!body) return '';
  const match = body.match(/## Summary & Interview Framing\s*\n\n([\s\S]*?)(?=\n---|\n##)/);
  if (match) {
    const text = match[1].trim();
    const descLine = text.split(/\n\n/)[0].replace(/\*\*How it's asked:\*\*\s*/i, '').trim();
    return descLine || text.split(/\n/)[0];
  }
  return '';
}

// Calculate read time
function calcReadTime(body: string): number {
  if (!body) return 5;
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(5, Math.round(words / 250));
}

const base = import.meta.env.BASE_URL;

// Build article list with category info
const articles = allArticles.map((a: any) => {
  const slug = a.id.replace(/^system-design\//, '').replace(/\.md$/, '');
  return {
    id: a.id,
    slug,
    href: `${base}${a.id.replace(/^system-design\//, 'system-design/').replace(/\.md$/, '')}`,
    title: a.data?.title || a.id,
    description: extractDescription(a.body),
    difficulty: a.data?.difficulty,
    readTime: calcReadTime(a.body),
    listenTime: Math.round(calcReadTime(a.body) * 1.4),
    tags: a.data?.tags?.slice(0, 6) || [],
    category: systemDesignCategories[slug] || 'Other',
  };
});

// Group by category in display order
const categoryOrder = [
  'Foundations',
  'Databases & Storage',
  'Caching & Performance',
  'Messaging & Event-Driven',
  'Observability & DevOps',
  'Real-World System Designs',
  'AI/ML Infrastructure',
  'Other',
];

const grouped: Record<string, typeof articles> = {};
for (const cat of categoryOrder) {
  const inCat = articles.filter(a => a.category === cat).sort((a, b) => a.title.localeCompare(b.title));
  if (inCat.length > 0) grouped[cat] = inCat;
}
---

<BaseLayout title="System Design" description="{articles.length} in-depth System Design articles covering distributed systems, databases, caching, messaging, ML infrastructure, and real-world architecture." activeNav="system-design">
  <div class="category-page">
    <header class="page-header">
      <p class="category-eyebrow">CATEGORY</p>
      <h1 class="category-title">System Design</h1>
      <p class="category-subtitle">
        {articles.length} in-depth articles across {Object.keys(grouped).length} topics — distributed systems, databases, caching, messaging, ML infrastructure, and real-world architecture.
      </p>
    </header>

    <div class="category-list">
      {Object.entries(grouped).map(([catName, catArticles]) => (
        <CategorySection
          title={catName}
          count={catArticles.length}
          articles={catArticles.map(a => ({
            href: a.href,
            title: a.title,
            description: a.description,
            category: catName,
            difficulty: a.difficulty,
            readTime: a.readTime,
            listenTime: a.listenTime,
            tags: a.tags,
          }))}
          defaultOpen={catArticles.length <= 5}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .category-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .category-eyebrow {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }
  .category-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .category-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .category-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (max-width: 768px) {
    .category-title {
      font-size: 2rem;
    }
  }
</style>
