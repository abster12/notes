---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="not-found">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist.</p>
    <a href={import.meta.env.BASE_URL} class="back-link">← Back to home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    max-width: 600px;
    margin: 8rem auto;
    padding: 0 1.5rem;
    text-align: center;
  }
  h1 {
    font-size: 6rem;
    color: var(--color-accent);
    margin: 0;
    font-weight: 700;
  }
  p {
    color: var(--color-text-secondary);
    font-size: 1.2rem;
    margin: 1rem 0 2rem;
  }
  .back-link {
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
