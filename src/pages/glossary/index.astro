---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const glossaryArticles = await getCollection('articles', (entry: any) => entry.id.startsWith('glossary/'));

// Get the main Glossary.md (not Term-X.md files if any)
const mainGlossary = glossaryArticles.find((a: any) => a.id === 'glossary/Glossary' || a.id === 'glossary/glossary' || a.id === 'Glossary');

// Fall back to the first glossary article
const glossary = mainGlossary || glossaryArticles[0];

let Content: any = null;
let headings: any[] = [];
if (glossary) {
  const rendered = await render(glossary);
  Content = rendered.Content;
  headings = rendered.headings;
}
---

<BaseLayout title="Glossary" description="Comprehensive A-Z glossary of 150+ System Design, ML/AI, and coding interview terms. Quick reference for revision and lookup." activeNav="glossary">
  <div class="glossary-page">
    <header class="glossary-header">
      <p class="glossary-eyebrow">REFERENCE</p>
      <h1 class="glossary-title">Glossary</h1>
      <p class="glossary-subtitle">
        150+ terms across System Design, ML/AI, distributed systems, and coding interview topics.
        Use Cmd+F / Ctrl+F to search for any term.
      </p>
    </header>

    <div class="glossary-content article-prose">
      {Content && <Content />}
    </div>
  </div>
</BaseLayout>

<style>
  .glossary-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .glossary-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .glossary-eyebrow {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }
  .glossary-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .glossary-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  .glossary-content {
    max-width: 100%;
  }
</style>
